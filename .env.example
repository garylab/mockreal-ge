# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=12345678
DB_NAME=mockreal_ge

# App
APP_PORT=8000
PIPELINE_INTERVAL_HOURS=6
METRICS_HOUR=3
SCORE_THRESHOLD=7

# Metabase
METABASE_PORT=3000
GENERIC_TIMEZONE=UTC

# Anthropic / Claude (article writing + content regeneration)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI / ChatGPT (topic scoring + image generation)
OPENAI_API_KEY=sk-your-openai-api-key

# Data Sources
SERPAPI_KEY=your-serpapi-key
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Telegram (approval flow)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Publishing - Website (POST /api/blogs/create with X-API-Key header)
WEBSITE_API_URL=https://mockreal.com
WEBSITE_API_KEY=your-secret-key

# Publishing - Medium
MEDIUM_API_TOKEN=your-medium-api-token
MEDIUM_AUTHOR_ID=your-medium-author-id

# Publishing - LinkedIn
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=your-linkedin-person-urn

# Publishing - Facebook
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_ACCESS_TOKEN=your-facebook-access-token

# Pexels (section images)
PEXELS_API_KEY=your-pexels-api-key

# Cloudflare R2 (image storage, S3-compatible)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Content controls (comma-separated blacklist keywords, publish hours in 24h)
TOPIC_BLACKLIST=competitor-name,off-topic-keyword
PUBLISH_HOURS=8,12,18

# Dashboard / Analytics
DASHBOARD_WEBHOOK_URL=https://your-analytics-endpoint.com/ingest
